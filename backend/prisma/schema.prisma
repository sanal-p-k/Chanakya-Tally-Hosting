datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model WindowsServer {
  id          String    @id @default(uuid())
  name        String
  publicIp    String
  privateIp   String
  status      String    @default("ONLINE") // ONLINE, OFFLINE, MAINTENANCE, REBOOTING
  os          String    @default("Windows Server 2022")
  ram         String    @default("32 GB")
  cpu         String    @default("8 vCPU")
  storage     String    @default("500 GB NVMe SSD")
  health      String    @default("HEALTHY") // HEALTHY, WARNING, CRITICAL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companies   Company[]
}

model Company {
  id              String               @id @default(uuid())
  name            String
  status          String               @default("ACTIVE") // ACTIVE, SUSPENDED, INACTIVE
  slug            String               @unique
  windowsServerId String?
  windowsServer   WindowsServer?       @relation(fields: [windowsServerId], references: [id], onDelete: SetNull)
  windowsUsername String?              @unique
  windowsPassword String?              // Encrypted AES Windows password
  provisionStatus String               @default("PROVISIONED") // PENDING, PROVISIONED, FAILED
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  users           User[]
  applications    CompanyApplication[]
  sessions        SessionLog[]
}

model User {
  id                  String            @id @default(uuid())
  name                String
  email               String            @unique
  password            String
  provisionStatus     String            @default("PROVISIONED") // PENDING, PROVISIONED, FAILED
  role                String            @default("USER") // SUPER_ADMIN, COMPANY_ADMIN, USER
  status              String            @default("ACTIVE") // ACTIVE, DISABLED
  companyId           String?
  company             Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  allowedApplications UserApplication[]
  sessions            SessionLog[]
}

model Application {
  id                    String               @id @default(uuid())
  name                  String
  icon                  String               @default("AppWindow") // Lucide icon component name
  description           String?
  executable            String
  guacamoleConnectionId String?              // Optional: standard Guacamole connection ID if connecting to a real server
  guacamoleConfig       Json?                // Optional: JSON configurations like protocol, port, hostname, password
  status                String               @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  companies             CompanyApplication[]
  users                 UserApplication[]
}

model CompanyApplication {
  companyId     String
  applicationId String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([companyId, applicationId])
}

model UserApplication {
  userId        String
  applicationId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([userId, applicationId])
}

model SessionLog {
  id              String    @id @default(uuid())
  userId          String
  companyId       String
  applicationId   String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applicationName String
  launchedAt      DateTime  @default(now())
  endedAt         DateTime?
  status          String    @default("ACTIVE") // ACTIVE, COMPLETED, FAILED
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  action    String
  module    String
  status    String   // SUCCESS, INFO, WARNING, FAILED
  message   String
  operator  String
  details   String?
}
